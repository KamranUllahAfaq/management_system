generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Student {
  id                 Int            @id @default(autoincrement())
  username           String         @unique
  password           String
  name               String
  email              String         @unique
  rollNumber         String
  hostelName         String
  roomNumber         String
  balanceDue         Float
  mobile             String
  emergencyContact   String
  profileImage       String?
  fatherName         String         @default("")
  cnic               String         @default("")
  permanentAddress   String         @default("")
  semester           String         @default("")
  registrationNumber String         @default("")
  university         String         @default("")
  fine               Float          @default(0.0)
  transportUsing     Boolean        @default(false)
  monthlyFee         Float          @default(25000.0)
  accountStatus      String         @default("Active") // "Active", "Inactive"
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  
  branchId           Int
  branch             Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roomId             Int?
  room               Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  
  roommates          Roommate[]
  payments           Payment[]
  complaints         Complaint[]
  notifications      Notification[]
}

model Branch {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  type      String    // "Girls", "Boys"
  students  Student[]
  rooms     Room[]
  wardens   Warden[]
  staff     Staff[]
}

model Room {
  id           Int       @id @default(autoincrement())
  roomNumber   String
  floor        String
  roomType     String    // "Single", "Double", "Triple", "Quad"
  totalBeds    Int
  occupiedBeds Int       @default(0)
  status       String    @default("Available") // "Available", "Full", "Maintenance", "Reserved"
  branchId     Int
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  students     Student[]
}

model Warden {
  id            Int      @id @default(autoincrement())
  name          String
  contact       String
  email         String
  shift         String   // "Day", "Night"
  salary        Float
  assignedFloor String
  status        String   @default("Active") // "Active", "On Leave"
  branchId      Int
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Staff {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   // "Mess Staff", "Working Maid", "Sanitary Staff", "Security Guard", "Maintenance Staff", "Driver", "Other"
  role        String?  // "Cook", "Assistant Cook", "Mess Manager", "Food Server", etc.
  contact     String
  salary      Float
  dutyArea    String
  shift       String   // "Day", "Night", "Rotating"
  status      String   @default("Active") // "Active", "On Leave", "Suspended"
  joiningDate String
  branchId    Int
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
}

model Roommate {
  id         Int      @id @default(autoincrement())
  name       String
  rollNumber String
  mobile     String
  email      String
  studentId  Int
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Payment {
  id            Int      @id @default(autoincrement())
  month         String
  dueDate       String
  amount        Float
  status        String   // "Paid", "Pending", "Partial Paid", "Overdue"
  paymentDate   String?
  transactionId String?
  method        String?
  verifiedBy    String?  // Admin username who verified this
  adminNote     String?  // Reject reason or verification note
  studentId     Int
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Complaint {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  description String
  status      String   // "Open", "In Progress", "Resolved", "Rejected"
  date        String
  roomNumber  String
  priority    String   @default("Normal") // "Normal", "Important", "Urgent"
  assignedTo  String?  // Name/Role of staff assigned
  adminNote   String?  // Response from Admin
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  type      String   // "Info", "Warning", "Alert"
  date      String
  priority  String   @default("Normal") // "Normal", "Important", "Urgent"
  read      Boolean  @default(false)
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TransportRoute {
  id          Int    @id @default(autoincrement())
  routeNumber String
  destination String
  departure   String
  status      String // "Active", "Delayed", "Cancelled"
  driverName  String
  contact     String
}
